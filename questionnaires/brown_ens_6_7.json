    {"id": "focus",      "label": "Focus",       "items_ids": ["2","10","16","27","32","42","44","48","51"],    "score_max": 27},
    {"id": "effort",     "label": "Effort",      "items_ids": ["4","8","17","21","25","28","39","46","50"],     "score_max": 27},
    {"id": "emotion",    "label": "Émotion",     "items_ids": ["3","6","12","19","24","29","33","37","52"],     "score_max": 27},
    {"id": "memoire",    "label": "Mémoire",     "items_ids": ["5","9","13","15","22","30","35","38","54"],     "score_max": 27},
