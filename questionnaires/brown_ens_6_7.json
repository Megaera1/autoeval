  ],
  "items": [
    {"id":"1",  "sous_echelle":"activation","ordre_affichage":1,  "texte":"Semble avoir du mal à se mettre à ses exercices ou à d'autres tâches demandées.",                                                                                                      "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"2",  "sous_echelle":"focus",     "ordre_affichage":2,  "texte":"Se désintéresse facilement pendant qu'il (elle) écoute une histoire.",                                                                                                                  "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"3",  "sous_echelle":"emotion",   "ordre_affichage":3,  "texte":"Passe trop de temps sur des petits détails dans le but d'atteindre la perfection.",                                                                                                     "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"4",  "sous_echelle":"effort",    "ordre_affichage":4,  "texte":"Sauf pendant ses activités préférées, semble fatigué(e) ou avoir sommeil pendant les cours.",                                                                                           "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"5",  "sous_echelle":"memoire",   "ordre_affichage":5,  "texte":"A du mal à se rappeler des choses qu'il (elle) vient tout juste d'entendre ou de lire.",                                                                                                "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"6",  "sous_echelle":"emotion",   "ordre_affichage":6,  "texte":"Semble débordé(e) par des tâches quotidiennes et des situations qu'il (elle) devrait pourtant pouvoir gérer.",                                                                          "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"7",  "sous_echelle":"activation","ordre_affichage":7,  "texte":"A du mal à passer d'une activité à une autre.",                                                                                                                                         "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"8",  "sous_echelle":"effort",    "ordre_affichage":8,  "texte":"A besoin de temps supplémentaire pour finir ses exercices.",                                                                                                                             "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"9",  "sous_echelle":"memoire",   "ordre_affichage":9,  "texte":"A du mal à suivre les consignes, en particulier si on lui donne plusieurs choses à faire en même temps.",                                                                               "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"10", "sous_echelle":"focus",     "ordre_affichage":10, "texte":"Se laisse facilement distraire par des bruits de fond ou par d'autres activités se déroulant en même temps.",                                                                           "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"11", "sous_echelle":"action",    "ordre_affichage":11, "texte":"A du mal à rester assis(e) sans s'agiter et à rester silencieux(se) lorsqu'on lui demande.",                                                                                            "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"12", "sous_echelle":"emotion",   "ordre_affichage":12, "texte":"Se fait trop de soucis.",                                                                                                                                                               "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"13", "sous_echelle":"memoire",   "ordre_affichage":13, "texte":"A du mal à comprendre l'idée principale d'une histoire peu captivante après l'avoir lue ou entendue.",                                                                                  "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"14", "sous_echelle":"action",    "ordre_affichage":14, "texte":"Interrompt les autres lorsqu'ils (elles) sont en train de faire ou dire quelque chose.",                                                                                                 "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"15", "sous_echelle":"memoire",   "ordre_affichage":15, "texte":"Oublie d'amener ou égare des choses dont il (elle) a besoin comme ses livres, ses jouets ou son manteau.",                                                                              "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"16", "sous_echelle":"focus",     "ordre_affichage":16, "texte":"A du mal à se concentrer sur quelque chose pendant un long moment à moins que la tâche l'intéresse.",                                                                                   "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"17", "sous_echelle":"effort",    "ordre_affichage":17, "texte":"Abandonne rapidement lorsqu'il (elle) essaie d'apprendre quelque chose de nouveau si c'est difficile.",                                                                                 "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"18", "sous_echelle":"activation","ordre_affichage":18, "texte":"A beaucoup de mal à démarrer des tâches comme ranger derrière soi ou se préparer à rentrer en classe.",                                                                                 "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"19", "sous_echelle":"emotion",   "ordre_affichage":19, "texte":"Se montre excessivement sensible, susceptible ou trop sur la défensive en cas de critique ou de moquerie.",                                                                             "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"20", "sous_echelle":"action",    "ordre_affichage":20, "texte":"Commence à faire des choses sans attendre l'autorisation ou les consignes.",                                                                                                            "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"21", "sous_echelle":"effort",    "ordre_affichage":21, "texte":"Obtient des notes variables à l'école, parfois bonnes, parfois mauvaises.",                                                                                                             "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"22", "sous_echelle":"memoire",   "ordre_affichage":22, "texte":"Semble perdre le fil ou s'exprime de manière incohérente lorsqu'il (elle) parle.",                                                                                                      "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"23", "sous_echelle":"action",    "ordre_affichage":23, "texte":"S'impatiente et se met à remuer excessivement ses doigts, à tripoter ses cheveux ou ses vêtements.",                                                                                    "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"24", "sous_echelle":"emotion",   "ordre_affichage":24, "texte":"Se sent frustré(e) et se montre irritable face à de petits désagréments.",                                                                                                              "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"25", "sous_echelle":"effort",    "ordre_affichage":25, "texte":"Son écriture n'est pas soignée et est difficile à lire.",                                                                                                                               "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"26", "sous_echelle":"activation","ordre_affichage":26, "texte":"Met du temps à répondre aux questions ou à réagir aux sollicitations des autres.",                                                                                                      "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"27", "sous_echelle":"focus",     "ordre_affichage":27, "texte":"A besoin que les consignes soient répétées plusieurs fois avant de les comprendre.",                                                                                                    "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"28", "sous_echelle":"effort",    "ordre_affichage":28, "texte":"Peu après avoir commencé une tâche ou un exercice, s'ennuie et ne veut pas terminer.",                                                                                                  "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"29", "sous_echelle":"emotion",   "ordre_affichage":29, "texte":"Est timide et ne parle ou ne joue pas beaucoup avec les enfants de son âge.",                                                                                                           "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"30", "sous_echelle":"memoire",   "ordre_affichage":30, "texte":"Oublie les règles ou les routines d'un jour à l'autre.",                                                                                                                                "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"31", "sous_echelle":"action",    "ordre_affichage":31, "texte":"A tendance à grimper partout.",                                                                                                                                                         "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"32", "sous_echelle":"focus",     "ordre_affichage":32, "texte":"A besoin qu'on lui rappelle de continuer de travailler ou d'être attentif(ve).",                                                                                                        "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"33", "sous_echelle":"emotion",   "ordre_affichage":33, "texte":"Se montre si stressé(e) pendant les interrogations qu'il (elle) est incapable de se rappeler des choses pourtant connues la veille.",                                                   "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"34", "sous_echelle":"activation","ordre_affichage":34, "texte":"Est trop dans la lune.",                                                                                                                                                                "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"35", "sous_echelle":"memoire",   "ordre_affichage":35, "texte":"Semble avoir du mal à organiser ses pensées à l'écrit ou lors de conversations.",                                                                                                       "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"36", "sous_echelle":"action",    "ordre_affichage":36, "texte":"Parle beaucoup et semble avoir du mal à savoir quand s'arrêter.",                                                                                                                        "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"37", "sous_echelle":"emotion",   "ordre_affichage":37, "texte":"Semble triste ou déprimé(e).",                                                                                                                                                          "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"38", "sous_echelle":"memoire",   "ordre_affichage":38, "texte":"A du mal à se rappeler des choses comme des couleurs, des formes, des nombres ou des lettres.",                                                                                         "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"39", "sous_echelle":"effort",    "ordre_affichage":39, "texte":"A besoin qu'on lui rappelle de commencer ou de continuer le travail sur les tâches à accomplir.",                                                                                       "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"40", "sous_echelle":"activation","ordre_affichage":40, "texte":"Le travail semble bâclé ou n'est pas terminé.",                                                                                                                                         "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"41", "sous_echelle":"action",    "ordre_affichage":41, "texte":"Taquine les autres, se querelle, se plaint ou se comporte mal, même après un rappel à l'ordre.",                                                                                        "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"42", "sous_echelle":"focus",     "ordre_affichage":42, "texte":"Reste bloqué(e) sur une activité et a du mal à passer à une autre activité plus importante.",                                                                                           "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"43", "sous_echelle":"activation","ordre_affichage":43, "texte":"A besoin qu'on lui dise ou montre plusieurs fois les mêmes consignes pour les suivre correctement.",                                                                                    "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"44", "sous_echelle":"focus",     "ordre_affichage":44, "texte":"Se laisse distraire alors qu'on lui a assigné une tâche, et oublie ce qu'il (elle) est censé(e) faire.",                                                                               "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"45", "sous_echelle":"action",    "ordre_affichage":45, "texte":"A du mal à cesser des comportements qui perturbent la classe comme bavarder avec ses camarades, même si on lui demande.",                                                               "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"46", "sous_echelle":"effort",    "ordre_affichage":46, "texte":"S'ennuie facilement.",                                                                                                                                                                  "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"47", "sous_echelle":"action",    "ordre_affichage":47, "texte":"Semble dire ou faire des choses sans penser préalablement aux conséquences possibles.",                                                                                                 "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
