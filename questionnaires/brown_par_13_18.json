[{
  "id": "brown_par_13_18",
  "nom": "Échelles Brown Attention/Fonctions Exécutives — Version Parents 13-18 ans",
  "auteurs": "Thomas E. Brown",
  "editeur": "© 2019-2020 NCS Pearson / ECPA",
  "tranche_age": "13-18 ans",
  "mode_passation": "Hétéro-évaluation (parents)",
  "parent_mode": true,
  "omission_default_score": 1,
  "info_fields": [
    {"id": "_meta_evaluateur",     "label": "Nom de l'évaluateur",  "type": "text", "required": true,  "placeholder": "Prénom Nom"},
    {"id": "_meta_date_evaluation","label": "Date de l'évaluation", "type": "date", "required": false},
    {"id": "_meta_lien_parente",   "label": "Lien de parenté",      "type": "text", "required": false, "placeholder": "ex : mère, père, tuteur"}
  ],
  "instructions": "Lisez chaque énoncé avec attention. Pour chaque énoncé, choisissez la réponse qui décrit le mieux l'intensité des sensations ou des comportements que vous pensez avoir été vécus comme problématiques par votre enfant au cours des six derniers mois. Ce problème peut être considéré comme très important, moyennement important ou peu important, qu'il se soit produit fréquemment ou rarement pendant cette période.",
  "sous_echelles": [
    {"id": "activation", "label": "Activation", "items_ids": ["1","7","18","25","28","34","40","43","53"],          "score_max": 27},
    {"id": "focus",      "label": "Focus",       "items_ids": ["3","8","17","32","42","44","46","50","56"],          "score_max": 27},
    {"id": "effort",     "label": "Effort",      "items_ids": ["4","10","16","21","29","35","39","45","52","55"],    "score_max": 30},
    {"id": "emotion",    "label": "Émotion",     "items_ids": ["6","12","19","24","27","33","37","48","51"],         "score_max": 27},
    {"id": "memoire",    "label": "Mémoire",     "items_ids": ["5","9","13","15","22","26","30","38","41","57"],     "score_max": 30},
    {"id": "action",     "label": "Action",      "items_ids": ["2","11","14","20","23","31","36","47","49","54"],    "score_max": 30}
  ],
  "items": [
    {"id":"1",  "sous_echelle":"activation","ordre_affichage":1,  "texte":"Semble avoir du mal à se mettre à ses devoirs ou à d'autres tâches demandées.",                                                                                                                                         "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"2",  "sous_echelle":"action",    "ordre_affichage":2,  "texte":"Commence à s'agiter et à se montrer impatient(e) lorsqu'il (elle) doit rester assis(e) sans bouger ou faire la queue.",                                                                                                 "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"3",  "sous_echelle":"focus",     "ordre_affichage":3,  "texte":"A besoin qu'on lui rappelle de continuer de travailler ou d'être attentif(ve).",                                                                                                                                        "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"4",  "sous_echelle":"effort",    "ordre_affichage":4,  "texte":"Sauf pendant ses activités préférées, semble fatigué(e) ou avoir sommeil en pleine journée, même après une nuit de sommeil complète.",                                                                                  "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"5",  "sous_echelle":"memoire",   "ordre_affichage":5,  "texte":"A du mal à suivre les consignes, en particulier si on lui donne plusieurs choses à faire en même temps.",                                                                                                               "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"6",  "sous_echelle":"emotion",   "ordre_affichage":6,  "texte":"Semble débordé(e) par des tâches quotidiennes et des situations qu'il (elle) devrait pourtant pouvoir gérer.",                                                                                                          "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"7",  "sous_echelle":"activation","ordre_affichage":7,  "texte":"A du mal à passer d'une activité à une autre.",                                                                                                                                                                         "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"8",  "sous_echelle":"focus",     "ordre_affichage":8,  "texte":"Se laisse facilement distraire par des bruits de fond ou par d'autres activités se déroulant en même temps.",                                                                                                           "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"9",  "sous_echelle":"memoire",   "ordre_affichage":9,  "texte":"A du mal à prendre des notes en classe tout en écoutant ce qu'il se dit d'autre.",                                                                                                                                      "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"10", "sous_echelle":"effort",    "ordre_affichage":10, "texte":"A besoin de temps supplémentaire pour finir des tâches routinières comme ses devoirs ou des tâches ménagères.",                                                                                                         "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"11", "sous_echelle":"action",    "ordre_affichage":11, "texte":"Coupe la parole aux autres pour dire quelque chose avant d'oublier ce qu'il (elle) voulait dire.",                                                                                                                      "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"12", "sous_echelle":"emotion",   "ordre_affichage":12, "texte":"Se soucie trop du fait que les choses pourraient mal se passer, ou de ce que pourraient penser les autres.",                                                                                                            "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"13", "sous_echelle":"memoire",   "ordre_affichage":13, "texte":"Se rappelle certains détails dans les devoirs de lecture, mais a du mal à en comprendre les idées principales.",                                                                                                        "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"14", "sous_echelle":"action",    "ordre_affichage":14, "texte":"Semble ne pas remarquer lorsqu'il (elle) ennuie, déroute ou irrite les autres.",                                                                                                                                        "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"15", "sous_echelle":"memoire",   "ordre_affichage":15, "texte":"Oublie d'amener ou égare des choses dont il (elle) a besoin comme ses clés, son portefeuille, son sac ou ses devoirs.",                                                                                                "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"16", "sous_echelle":"effort",    "ordre_affichage":16, "texte":"Abandonne rapidement lorsqu'il (elle) essaie d'apprendre quelque chose de nouveau si c'est difficile.",                                                                                                                 "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"17", "sous_echelle":"focus",     "ordre_affichage":17, "texte":"A du mal à se concentrer sur quelque chose pendant un long moment à moins que la tâche l'intéresse.",                                                                                                                   "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"18", "sous_echelle":"activation","ordre_affichage":18, "texte":"A du mal à se réveiller, à sortir de son lit et à commencer sa journée.",                                                                                                                                               "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"19", "sous_echelle":"emotion",   "ordre_affichage":19, "texte":"Se sent frustré(e) et se montre irritable face à de petits désagréments.",                                                                                                                                              "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"20", "sous_echelle":"action",    "ordre_affichage":20, "texte":"S'impatiente et se met à remuer excessivement ses doigts, à tripoter ses cheveux ou ses vêtements.",                                                                                                                    "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"21", "sous_echelle":"effort",    "ordre_affichage":21, "texte":"A du mal à garder de l'intérêt pour les tâches routinières, surtout lorsqu'il (elle) travaille seul(e).",                                                                                                              "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"22", "sous_echelle":"memoire",   "ordre_affichage":22, "texte":"Semble perdre le fil ou s'exprime de manière incohérente lorsqu'il (elle) parle.",                                                                                                                                      "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"23", "sous_echelle":"action",    "ordre_affichage":23, "texte":"Semble souvent agité(e).",                                                                                                                                                                                              "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"24", "sous_echelle":"emotion",   "ordre_affichage":24, "texte":"Se montre excessivement sensible, susceptible ou trop sur la défensive en cas de critique ou de moquerie.",                                                                                                             "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"25", "sous_echelle":"activation","ordre_affichage":25, "texte":"A du mal à s'organiser et à commencer par les choses les plus importantes sans perdre de temps.",                                                                                                                       "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"26", "sous_echelle":"memoire",   "ordre_affichage":26, "texte":"Oublie une grande partie de ce qu'il (elle) vient tout juste d'entendre dans une conversation.",                                                                                                                        "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"27", "sous_echelle":"emotion",   "ordre_affichage":27, "texte":"Passe trop de temps sur des petits détails dans le but d'atteindre la perfection.",                                                                                                                                     "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"28", "sous_echelle":"activation","ordre_affichage":28, "texte":"A tendance à être désorganisé(e) et à oublier les dates butoirs pour rendre ses devoirs et pour les contrôles.",                                                                                                        "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"29", "sous_echelle":"effort",    "ordre_affichage":29, "texte":"Semble avoir du mal à s'endormir le soir.",                                                                                                                                                                             "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"30", "sous_echelle":"memoire",   "ordre_affichage":30, "texte":"Oublie ou ajoute des lettres ou des mots quand il (elle) écrit.",                                                                                                                                                       "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"31", "sous_echelle":"action",    "ordre_affichage":31, "texte":"Semble dire ou faire des choses sans penser préalablement aux conséquences possibles.",                                                                                                                                 "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"32", "sous_echelle":"focus",     "ordre_affichage":32, "texte":"A besoin que les consignes soient répétées plusieurs fois avant de les comprendre.",                                                                                                                                    "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"33", "sous_echelle":"emotion",   "ordre_affichage":33, "texte":"Ne semble pas beaucoup se préoccuper de son travail scolaire.",                                                                                                                                                         "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"34", "sous_echelle":"activation","ordre_affichage":34, "texte":"Est trop dans la lune.",                                                                                                                                                                                                "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"35", "sous_echelle":"effort",    "ordre_affichage":35, "texte":"A du mal à terminer des tâches routinières qu'il (elle) trouve peu intéressantes.",                                                                                                                                    "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"36", "sous_echelle":"action",    "ordre_affichage":36, "texte":"Parle beaucoup et semble avoir du mal à savoir quand s'arrêter.",                                                                                                                                                        "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"37", "sous_echelle":"emotion",   "ordre_affichage":37, "texte":"Semble triste ou déprimé(e).",                                                                                                                                                                                          "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"38", "sous_echelle":"memoire",   "ordre_affichage":38, "texte":"A du mal à se rappeler des choses comme des mots de vocabulaire, des noms et des dates.",                                                                                                                               "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"39", "sous_echelle":"effort",    "ordre_affichage":39, "texte":"A besoin qu'on lui rappelle de commencer ou de continuer le travail sur les tâches à accomplir.",                                                                                                                       "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"40", "sous_echelle":"activation","ordre_affichage":40, "texte":"Son travail semble bâclé, n'est pas terminé ou est rendu en retard.",                                                                                                                                                   "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"41", "sous_echelle":"memoire",   "ordre_affichage":41, "texte":"A du mal à comprendre et à se rappeler les consignes lors des contrôles ou pour les devoirs.",                                                                                                                          "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"42", "sous_echelle":"focus",     "ordre_affichage":42, "texte":"Semble se déconcentrer facilement lorsqu'il (elle) lit ou écoute quelque chose de peu captivant.",                                                                                                                     "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"43", "sous_echelle":"activation","ordre_affichage":43, "texte":"Attend la dernière minute pour faire les choses.",                                                                                                                                                                      "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"44", "sous_echelle":"focus",     "ordre_affichage":44, "texte":"Reste bloqué(e) sur une activité et a du mal à passer à une autre activité plus importante.",                                                                                                                          "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"45", "sous_echelle":"effort",    "ordre_affichage":45, "texte":"Obtient des notes variables à l'école, parfois bonnes, parfois mauvaises.",                                                                                                                                             "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"46", "sous_echelle":"focus",     "ordre_affichage":46, "texte":"Est difficile à comprendre car il (elle) parle trop vite ou n'arrête pas de changer de sujet lorsqu'il (elle) s'exprime.",                                                                                             "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"47", "sous_echelle":"action",    "ordre_affichage":47, "texte":"Commence à faire des choses sans attendre l'autorisation ou les consignes.",                                                                                                                                            "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
