    {"id":"35", "sous_echelle":"effort",    "ordre_affichage":35, "texte":"Certains jours, je fais vraiment du bon travail à l'école, et d'autres jours, ce n'est pas terrible.",                                                                       "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"36", "sous_echelle":"action",    "ordre_affichage":36, "texte":"Je parle beaucoup et j'ai du mal à savoir quand m'arrêter.",                                                                                                                  "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"37", "sous_echelle":"emotion",   "ordre_affichage":37, "texte":"Je me sens triste ou malheureux(se).",                                                                                                                                        "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"38", "sous_echelle":"memoire",   "ordre_affichage":38, "texte":"J'ai du mal à me rappeler des choses comme des mots de vocabulaire, des noms et des dates.",                                                                                  "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"39", "sous_echelle":"effort",    "ordre_affichage":39, "texte":"J'ai besoin qu'on me rappelle de commencer ou de continuer mes devoirs ou les tâches ménagères à la maison.",                                                                 "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"40", "sous_echelle":"activation","ordre_affichage":40, "texte":"Mon travail est bâclé, pas terminé ou rendu en retard parce que je ne prévois pas assez de temps pour le faire correctement.",                                                "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"41", "sous_echelle":"action",    "ordre_affichage":41, "texte":"J'interromps les autres lorsqu'ils (elles) sont en train de faire ou de dire quelque chose.",                                                                                 "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"42", "sous_echelle":"focus",     "ordre_affichage":42, "texte":"Je reste bloqué(e) sur une activité et j'ai du mal à passer à une autre activité plus importante.",                                                                          "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"43", "sous_echelle":"activation","ordre_affichage":43, "texte":"J'attends la dernière minute pour faire les choses.",                                                                                                                         "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
    {"id":"44", "sous_echelle":"effort",    "ordre_affichage":44, "texte":"J'ai du mal à terminer les choses qui ne m'intéressent pas.",                                                                                                                 "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
