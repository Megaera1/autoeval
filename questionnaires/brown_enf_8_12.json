    {"id":"46", "sous_echelle":"activation","ordre_affichage":46, "texte":"À l'école, j'ai du mal à m'y retrouver dans mes devoirs et à les rendre à la date prévue.",                                                                                  "type":"apmt","options":[{"code":"A","label":"Aucun problème","valeur":0},{"code":"P","label":"Problème Peu important","valeur":1},{"code":"M","label":"Problème Moyennement important","valeur":2},{"code":"T","label":"Problème Très important","valeur":3}]},
