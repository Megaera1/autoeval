{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié — AutoEval{% endblock %}

{% block navbar %}{% endblock %}

{% block page_wrapper %}
<div class="page page-center" style="min-height: 100vh; background-color: #f4f6fa;">
    <div class="container container-tight py-5">

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible mb-3">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="card shadow-sm" style="border-radius: 12px; max-width: 420px; margin: 0 auto;">

            <div class="card-body text-center pt-5 pb-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-lock-open mb-3" width="52" height="52" viewBox="0 0 24 24" stroke-width="1.5" stroke="#2c7be5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <rect x="5" y="11" width="14" height="10" rx="2"/>
                    <circle cx="12" cy="16" r="1"/>
                    <path d="M8 11v-5a4 4 0 0 1 8 0"/>
                </svg>
                <h1 class="h2 fw-bold mb-1" style="color: #2c7be5;">Mot de passe oublié</h1>
                <p class="text-muted mb-0 small">Saisissez votre email pour recevoir un lien de réinitialisation.</p>
            </div>

            <div class="card-body">
                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                <div class="mb-4">
                    {{ form_label(form.email, null, {'label_attr': {'class': 'form-label'}}) }}
                    <div class="input-group">
                        <span class="input-group-text">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-mail" width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <rect x="3" y="5" width="18" height="14" rx="2"/>
                                <polyline points="3 7 12 13 21 7"/>
                            </svg>
                        </span>
                        {{ form_widget(form.email, {'attr': {'class': 'form-control' ~ (form.email.vars.errors|length ? ' is-invalid' : '')}}) }}
                        {{ form_errors(form.email) }}
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 mb-3">
                    Envoyer le lien de réinitialisation
                </button>

                {{ form_end(form) }}

                <div class="text-center">
                    <a href="{{ path('app_login') }}" class="text-muted small">
                        &larr; Retour à la connexion
                    </a>
                </div>
            </div>

        </div>

        <p class="text-center text-muted small mt-4">
            AutoEval &copy; 2025 — Usage clinique exclusif
        </p>

    </div>
</div>
{% endblock %}
