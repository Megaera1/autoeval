{% extends 'base.html.twig' %}

{% block title %}{{ patient.fullName }} — AutoEval{% endblock %}

{% block navbar %}
<header class="navbar navbar-expand-md navbar-dark bg-blue d-print-none">
    <div class="container-xl">
        <a href="{{ path('app_admin_dashboard') }}" class="navbar-brand navbar-brand-autodark">
            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-brain me-2" width="28" height="28" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M15.5 13a3.5 3.5 0 0 0 -3.5 3.5v1a3.5 3.5 0 0 0 7 0v-1.8"/>
                <path d="M8.5 13a3.5 3.5 0 0 1 3.5 3.5v1a3.5 3.5 0 0 1 -7 0v-1.8"/>
                <path d="M17.5 16a3.5 3.5 0 0 0 0 -7h-.5"/>
                <path d="M19 9.3v-2.8a3.5 3.5 0 0 0 -7 0"/>
                <path d="M6.5 16a3.5 3.5 0 0 1 0 -7h.5"/>
                <path d="M5 9.3v-2.8a3.5 3.5 0 0 1 7 0v10"/>
            </svg>
            <strong>AutoEval</strong>
        </a>
        <div class="navbar-nav ms-auto d-flex align-items-center gap-3">
            <span class="text-white small">Dr {{ app.user.lastName }}</span>
            <a href="{{ path('app_logout') }}" class="btn btn-outline-light btn-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-logout me-1" width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M14 8v-2a2 2 0 0 0 -2 -2h-7a2 2 0 0 0 -2 2v12a2 2 0 0 0 2 2h7a2 2 0 0 0 2 -2v-2"/>
                    <path d="M9 12h12l-3 -3"/><path d="M18 15l3 -3"/>
                </svg>
                Déconnexion
            </a>
        </div>
    </div>
</header>
{% endblock %}

{% block stylesheets %}
<style>
/* Brown ENS specific */
.ens-meta-block { background:#f0fafa; border-bottom:1px solid #ddd; }
.ens-cluster-bar { height:14px; border-radius:7px; overflow:hidden; background:#e9ecef; }
.ens-cluster-bar-fill { height:100%; border-radius:7px; transition:width .4s; }
.ens-score-low    { background:#28a745; }
.ens-score-mid    { background:#ffc107; }
.ens-score-high   { background:#dc3545; }
.ens-badge-low    { background:#d1e7dd; color:#0a3622; }
.ens-badge-mid    { background:#fff3cd; color:#664d03; }
.ens-badge-high   { background:#f8d7da; color:#58151c; }
/* DIVA specific */
.diva-score-card { border:1.5px solid #bee3f8; border-radius:8px; padding:.75rem 1rem; }
.diva-threshold-ok   { background:#d1e7dd; color:#0a3622; }
.diva-threshold-warn { background:#f8d7da; color:#58151c; }
.diva-yn-oui { color:#276749; font-weight:700; }
.diva-yn-non { color:#4a5568; }
.diva-yn-dash { color:#a0aec0; }
</style>
{% endblock %}

{% block body %}
{# Breadcrumb + en-tête #}
<div class="page-header mt-3">
    <div class="row align-items-center">
        <div class="col">
            <ol class="breadcrumb" aria-label="breadcrumbs">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_admin_dashboard') }}">Tableau de bord</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">{{ patient.fullName }}</li>
            </ol>
            <div class="d-flex align-items-center justify-content-between">
                <h2 class="page-title mt-1">{{ patient.fullName }}</h2>
                <a href="{{ path('app_admin_patient_export', {id: patient.id}) }}"
                   class="btn btn-outline-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-download me-1" width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2 -2v-2"/>
                        <polyline points="7 11 12 16 17 11"/>
                        <line x1="12" y1="4" x2="12" y2="16"/>
                    </svg>
                    Télécharger le dossier (.txt)
                </a>
            </div>
        </div>
    </div>
</div>

{# Informations personnelles #}
<div class="card mt-3">
    <div class="card-header bg-blue-lt">
        <h3 class="card-title">
            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-id-badge me-2" width="20" height="20" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <rect x="4" y="3" width="16" height="18" rx="2"/>
                <circle cx="12" cy="10" r="3"/>
                <line x1="8" y1="21" x2="8" y2="17"/>
                <line x1="16" y1="21" x2="16" y2="17"/>
                <path d="M8 17a4 4 0 0 1 8 0"/>
            </svg>
            Informations personnelles
        </h3>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl class="row mb-0">
                    <dt class="col-5 text-muted">Nom</dt>
                    <dd class="col-7">{{ patient.lastName }}</dd>
                    <dt class="col-5 text-muted">Prénom</dt>
                    <dd class="col-7">{{ patient.firstName }}</dd>
                    <dt class="col-5 text-muted">Date de naissance</dt>
                    <dd class="col-7">{{ patient.birthDate ? patient.birthDate|date('d/m/Y') : '—' }}</dd>
                    <dt class="col-5 text-muted">Âge actuel</dt>
                    <dd class="col-7">
                        {% set currentAge = patient.currentAge %}
                        {{ currentAge is not null ? currentAge ~ ' ans' : (patient.age ? patient.age ~ ' ans (saisi)' : '—') }}
                    </dd>
                    <dt class="col-5 text-muted">Genre</dt>
                    <dd class="col-7">{{ patient.gender ?? '—' }}</dd>
                </dl>
            </div>
            <div class="col-md-6">
                <dl class="row mb-0">
                    <dt class="col-5 text-muted">Email</dt>
                    <dd class="col-7">
                        <span class="badge bg-blue-lt text-blue">{{ patient.email }}</span>
                    </dd>
                    <dt class="col-5 text-muted">Inscription</dt>
                    <dd class="col-7">{{ patient.createdAt ? patient.createdAt|date('d/m/Y') : '—' }}</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

{# Assigner des questionnaires #}
<div class="card mt-4">
    <div class="card-header bg-blue-lt d-flex align-items-center justify-content-between">
        <h3 class="card-title mb-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-clipboard-check me-2" width="20" height="20" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M9 5h-2a2 2 0 0 0 -2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-12a2 2 0 0 0 -2 -2h-2"/>
                <rect x="9" y="3" width="6" height="4" rx="2"/>
                <path d="M9 14l2 2l4 -4"/>
            </svg>
            Assigner des questionnaires
        </h3>
        <span class="badge bg-blue text-white">{{ assignedIds|length }} assigné{{ assignedIds|length > 1 ? 's' : '' }}</span>
    </div>
    <div class="card-body">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        <form method="POST" action="{{ path('app_admin_assign_questionnaires', {id: patient.id}) }}">
            {% if questionnairesGrouped is empty %}
                <p class="text-muted">Aucun questionnaire disponible dans la base.</p>
            {% else %}
                <div class="row g-3">
                    {% for category, questionnaires in questionnairesGrouped %}
                    <div class="col-12">
                        <p class="mb-1 fw-semibold text-uppercase text-muted" style="font-size:.75rem;letter-spacing:.05em;">{{ category }}</p>
                        <div class="row g-2">
                            {% for q in questionnaires %}
                            <div class="col-md-6 col-lg-4">
                                <label class="form-check p-2 border rounded cursor-pointer {% if q.id in assignedIds %}border-primary bg-blue-lt{% endif %}" style="cursor:pointer;">
                                    <input class="form-check-input me-2" type="checkbox" name="questionnaires[]" value="{{ q.id }}"
                                        {% if q.id in assignedIds %}checked{% endif %}>
                                    <span class="form-check-label" style="font-size:.875rem;">{{ q.title }}</span>
                                </label>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                    {% endfor %}
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-device-floppy me-1" width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                            <path d="M6 4h10l4 4v10a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2v-12a2 2 0 0 1 2 -2"/>
                            <circle cx="12" cy="13" r="2"/>
                            <polyline points="14 4 14 8 8 8 8 4"/>
                        </svg>
                        Enregistrer les assignations
                    </button>
                </div>
            {% endif %}
        </form>
    </div>
</div>

{# Anamnèse #}
<div class="card mt-4">
    <div class="card-header bg-blue-lt">
        <h3 class="card-title">
            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-file-text me-2" width="20" height="20" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M14 3v4a1 1 0 0 0 1 1h4"/>
                <path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z"/>
                <line x1="9" y1="9" x2="10" y2="9"/>
                <line x1="9" y1="13" x2="15" y2="13"/>
                <line x1="9" y1="17" x2="15" y2="17"/>
            </svg>
            Anamnèse
            {% if anamnesis %}
                {% if anamnesis.isComplete %}
                    <span class="badge bg-success-lt text-success ms-2">Complète</span>
                {% else %}
                    <span class="badge bg-warning-lt text-warning ms-2">En cours</span>
                {% endif %}
            {% endif %}
        </h3>
    </div>
    <div class="card-body">
        {% if anamnesis and anamnesis.data is not empty %}
            <div class="d-flex align-items-center gap-3 mb-3">
                {% if anamnesisDefinition %}
                    <span class="badge bg-blue-lt text-blue">
                        {{ anamnesisDefinition.title }} — {{ anamnesisDefinition.ageRange }}
                    </span>
                {% endif %}
                <small class="text-muted">
                    Dernière modification : {{ anamnesis.updatedAt ? anamnesis.updatedAt|date('d/m/Y à H:i') : '—' }}
                </small>
            </div>

            {% if anamnesisDefinition %}
                {# JSON-driven display: iterate sections then fields #}
                {% set data = anamnesis.data %}
                {% for section in anamnesisDefinition.sections %}
                    {% set sectionHasData = false %}
                    {% for field in section.fields %}
                        {% if data[field.id] is defined and data[field.id] is not empty %}
                            {% set sectionHasData = true %}
                        {% endif %}
                    {% endfor %}
                    {% if sectionHasData %}
                        <h6 class="text-muted fw-semibold mb-2 mt-3" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;">
                            {{ section.title }}
                        </h6>
                        <div class="row">
                            {% for field in section.fields %}
                                {% if data[field.id] is defined and data[field.id] is not empty %}
                                    <div class="col-md-6 mb-3">
                                        <div class="text-muted small fw-bold text-uppercase" style="font-size:.7rem;letter-spacing:.05em;">
                                            {{ field.label }}
                                        </div>
                                        <div class="mt-1">
                                            {# Resolve select option label #}
                                            {% if field.type == 'select' and field.options is defined %}
                                                {% set rawVal = data[field.id] %}
                                                {% set resolved = rawVal %}
                                                {% for opt in field.options %}
                                                    {% if opt.value == rawVal %}{% set resolved = opt.label %}{% endif %}
                                                {% endfor %}
                                                {{ resolved }}
                                            {% else %}
                                                {{ data[field.id] }}
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    {% endif %}
                {% endfor %}
            {% else %}
                {# Legacy: flat key/value with anamnesisLabels #}
                <div class="row">
                    {% for key, value in anamnesis.data %}
                        {% if key != '_form_type' and value is not empty %}
                            <div class="col-md-6 mb-3">
                                <div class="text-muted small fw-bold text-uppercase" style="font-size: .7rem; letter-spacing: .05em;">
                                    {{ anamnesisLabels[key] ?? key }}
                                </div>
                                <div class="mt-1">{{ value }}</div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            {% endif %}
        {% else %}
            <div class="text-muted text-center py-3">Anamnèse non renseignée.</div>
        {% endif %}
    </div>
</div>

{# ══════════════════════════════════════════
   Questionnaires — accordion
   ══════════════════════════════════════════ #}
<div class="card mt-4">
    <div class="card-header bg-blue-lt">
        <h3 class="card-title">
            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-clipboard-list me-2" width="20" height="20" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M9 5h-2a2 2 0 0 0 -2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-12a2 2 0 0 0 -2 -2h-2"/>
                <rect x="9" y="3" width="6" height="4" rx="2"/>
                <line x1="9" y1="12" x2="9.01" y2="12"/>
                <line x1="13" y1="12" x2="15" y2="12"/>
                <line x1="9" y1="16" x2="9.01" y2="16"/>
                <line x1="13" y1="16" x2="15" y2="16"/>
            </svg>
            Questionnaires ({{ responses|length }})
        </h3>
    </div>

    <div class="card-body p-0">
        {% if responses is empty %}
            <div class="text-muted text-center py-4">Aucune passation enregistrée.</div>
        {% else %}
            <div class="accordion" id="accordion-responses">
                {% for i, response in responses %}
                    {% set q = response.questionnaire %}
                    {% set isTeacher = q.questions.teacher_mode is defined and q.questions.teacher_mode %}
                    {% set isParent = q.questions.parent_mode is defined and q.questions.parent_mode %}
                    {% set isAdolescent = q.questions.adolescent_mode is defined and q.questions.adolescent_mode %}
                    {% set isDiva = q.questions.diva_mode is defined and q.questions.diva_mode %}
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="heading-{{ i }}">
                            <button class="accordion-button {{ i > 0 ? 'collapsed' : '' }}"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#collapse-{{ i }}"
                                    aria-expanded="{{ i == 0 ? 'true' : 'false' }}"
                                    aria-controls="collapse-{{ i }}">
                                <div class="d-flex align-items-center gap-3 w-100 me-3">
                                    <span class="fw-bold">{{ q.title }}</span>
                                    {% if isTeacher %}
                                        <span class="badge bg-teal-lt text-teal" style="font-size:.7rem;">Enseignant</span>
                                    {% endif %}
                                    {% if isParent %}
                                        <span class="badge bg-blue-lt text-blue" style="font-size:.7rem;">Parents</span>
                                    {% endif %}
                                    {% if isAdolescent %}
                                        <span class="badge" style="background:#e0f2f0;color:#2d7068;font-size:.7rem;">Auto-questionnaire</span>
                                    {% endif %}
                                    {% if isDiva %}
                                        <span class="badge" style="background:#ebf4ff;color:#2c5282;font-size:.7rem;">DIVA 2.0</span>
                                    {% endif %}
                                    {% if response.isComplete %}
                                        <span class="badge bg-success-lt text-success">Terminé</span>
                                    {% else %}
                                        <span class="badge bg-warning-lt text-warning">En cours</span>
                                    {% endif %}
                                    <span class="text-muted small ms-auto d-flex align-items-center gap-2">
                                        {% set ageAtStart = response.patientAgeAtStart %}
                                        {% if ageAtStart is not null %}
                                            <span class="badge bg-blue-lt text-blue" title="Âge du patient lors de la passation">{{ ageAtStart }} ans</span>
                                        {% endif %}
                                        {{ response.startedAt ? response.startedAt|date('d/m/Y') : '' }}
                                        {% if response.score is not null and not isTeacher and not isParent and not isAdolescent and not isDiva %}
                                            — Score : <strong>{{ response.score }}</strong>
                                        {% endif %}
                                    </span>
                                </div>
                            </button>
                        </h2>
                        <div id="collapse-{{ i }}"
                             class="accordion-collapse collapse {{ i == 0 ? 'show' : '' }}"
                             aria-labelledby="heading-{{ i }}"
                             data-bs-parent="#accordion-responses">
                            <div class="accordion-body p-0">

                                {# ══════════════════════════════════════════════
                                   TEACHER MODE — Brown ENS rich display
                                   ══════════════════════════════════════════════ #}
                                {% if isTeacher %}
                                    {% set meta = response.answers %}
                                    {% set durationLabels = {
                                        'moins_1_mois': "< 1 mois",
                                        '1_2_mois': '1-2 mois',
                                        '3_5_mois': '3-5 mois',
                                        '6_11_mois': '6-11 mois',
                                        '12_mois_plus': '≥ 12 mois'
                                    } %}

                                    {# Meta info block #}
                                    <div class="ens-meta-block px-4 py-3">
                                        <div class="row g-2 small">
                                            <div class="col-md-3">
                                                <span class="text-muted">Élève :</span>
                                                <strong>{{ (meta['_meta_eleve_prenom'] ?? '') ~ ' ' ~ (meta['_meta_eleve_nom'] ?? '—') }}</strong>
                                                {% if meta['_meta_sexe'] is defined %}
                                                    <span class="badge bg-secondary-lt ms-1">{{ meta['_meta_sexe'] }}</span>
                                                {% endif %}
                                            </div>
                                            <div class="col-md-3">
                                                <span class="text-muted">Classe :</span>
                                                <strong>{{ meta['_meta_classe'] ?? '—' }}</strong>
                                            </div>
                                            <div class="col-md-3">
                                                <span class="text-muted">Évaluateur :</span>
                                                <strong>{{ meta['_meta_evaluateur'] ?? '—' }}</strong>
                                            </div>
                                            <div class="col-md-3">
                                                <span class="text-muted">Connaissance :</span>
                                                <strong>{{ durationLabels[meta['_meta_duree_connaissance'] ?? ''] ?? '—' }}</strong>
                                            </div>
                                            {% if meta['_meta_date_admin_annee'] is defined %}
                                            <div class="col-md-3">
                                                <span class="text-muted">Date passation :</span>
                                                <strong>{{ meta['_meta_date_admin_jour'] ?? '' }}/{{ meta['_meta_date_admin_mois'] ?? '' }}/{{ meta['_meta_date_admin_annee'] ?? '' }}</strong>
                                            </div>
                                            {% endif %}
                                            {% if meta['_meta_dn_annee'] is defined %}
                                            <div class="col-md-3">
                                                <span class="text-muted">Naissance :</span>
                                                <strong>{{ meta['_meta_dn_jour'] ?? '' }}/{{ meta['_meta_dn_mois'] ?? '' }}/{{ meta['_meta_dn_annee'] ?? '' }}</strong>
                                            </div>
                                            {% endif %}
                                            {% if meta['_meta_praticien'] is defined and meta['_meta_praticien'] is not empty %}
                                            <div class="col-md-3">
                                                <span class="text-muted">Praticien :</span>
                                                <strong>{{ meta['_meta_praticien'] }}</strong>
                                            </div>
                                            {% endif %}
                                            {% if meta['_meta_raisons'] is defined and meta['_meta_raisons'] is not empty %}
                                            <div class="col-12">
                                                <span class="text-muted">Raisons :</span> {{ meta['_meta_raisons'] }}
                                            </div>
                                            {% endif %}
                                        </div>
                                    </div>

                                    {# Scores table + bar chart #}
                                    {% if response.isComplete and q.questions.sous_echelles is defined %}
                                    {% set hasCorrection      = q.questions.omission_correction is defined and q.questions.omission_correction %}
                                    {% set hasOmissionDefault = q.questions.omission_default_score is defined %}
                                    {% set showOmissionCol    = hasCorrection or hasOmissionDefault %}
                                    <div class="px-4 py-3 border-bottom">
                                        <h5 class="mb-3 fw-bold" style="color:#4A9A9A;">Scores par cluster</h5>
                                        <div class="row g-4">
                                            {# Table #}
                                            <div class="{{ showOmissionCol ? 'col-md-7' : 'col-md-5' }}">
                                                <table class="table table-sm mb-0">
                                                    <thead class="table-light">
                                                        <tr>
                                                            <th>Cluster</th>
                                                            <th class="text-center">Brut</th>
                                                            {% if showOmissionCol %}
                                                            <th class="text-center">Omissions</th>
                                                            {% endif %}
                                                            {% if hasCorrection %}
                                                            <th class="text-center">Corrigé</th>
                                                            {% endif %}
                                                            <th class="text-center">Max</th>
                                                            <th class="text-center">%</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        {% set totalBrut = 0 %}
                                                        {% set totalMax  = 0 %}
                                                        {% for se in q.questions.sous_echelles %}
                                                            {% set seScore = meta['_score_' ~ se.id] ?? 0 %}
                                                            {% set pct = se.score_max > 0 ? (seScore / se.score_max * 100)|round : 0 %}
                                                            {% set totalBrut = totalBrut + seScore %}
                                                            {% set totalMax  = totalMax  + se.score_max %}
                                                            <tr>
                                                                <td>{{ se.label }}</td>
                                                                <td class="text-center fw-bold">{{ seScore }}</td>
                                                                {% if showOmissionCol %}
                                                                {% set omissions = meta['_score_' ~ se.id ~ '_omissions'] ?? '—' %}
                                                                <td class="text-center">
                                                                    {% if omissions is not same as('—') and omissions > 2 %}
                                                                        <span class="badge bg-danger-lt text-danger">{{ omissions }}</span>
                                                                    {% else %}
                                                                        {{ omissions }}
                                                                    {% endif %}
                                                                </td>
                                                                {% endif %}
                                                                {% if hasCorrection %}
                                                                {% set corrected = meta['_score_' ~ se.id ~ '_corrected'] %}
