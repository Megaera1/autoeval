                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>

                                            {# Bar chart #}
                                            <div class="{{ showOmissionCol ? 'col-md-5' : 'col-md-7' }}">
                                                <div class="d-flex flex-column gap-3">
                                                    {% for se in q.questions.sous_echelles %}
                                                        {% set seScore = meta['_score_' ~ se.id] ?? 0 %}
                                                        {% set pct = se.score_max > 0 ? (seScore / se.score_max * 100)|round : 0 %}
                                                        <div>
                                                            <div class="d-flex justify-content-between small mb-1">
                                                                <span class="fw-semibold">{{ se.label }}</span>
                                                                <span class="text-muted">{{ seScore }} / {{ se.score_max }}</span>
                                                            </div>
                                                            <div class="ens-cluster-bar">
                                                                <div class="ens-cluster-bar-fill
                                                                    {% if pct <= 33 %}ens-bar-low
                                                                    {% elseif pct <= 66 %}ens-bar-mid
                                                                    {% else %}ens-bar-high{% endif %}"
                                                                    style="width:{{ pct }}%"></div>
                                                            </div>
                                                        </div>
                                                    {% endfor %}
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    {# Item detail accordion #}
                                    {% set clusterColors = {
                                        'activation':'bg-teal-lt text-teal',
                                        'focus':'bg-green-lt text-green',
                                        'effort':'bg-purple-lt text-purple',
                                        'emotion':'bg-orange-lt text-orange',
                                        'memoire':'bg-blue-lt text-blue',
                                        'action':'bg-red-lt text-red'
                                    } %}
                                    {% set clusterLabels = {} %}
                                    {% for se in q.questions.sous_echelles %}
                                        {% set clusterLabels = clusterLabels|merge({(se.id): se.label}) %}
                                    {% endfor %}
                                    <div class="px-4 py-3">
                                        <div class="accordion accordion-flush" id="ado-items-accordion">
                                            <div class="accordion-item border-0">
                                                <h2 class="accordion-header">
                                                    <button class="accordion-button collapsed ps-0 fw-semibold text-muted small" type="button"
                                                            data-bs-toggle="collapse" data-bs-target="#ado-items-detail">
                                                        Détail des réponses ({{ q.questions.items|length }} items)
                                                    </button>
                                                </h2>
                                                <div id="ado-items-detail" class="accordion-collapse collapse">
                                                    <table class="table table-sm table-hover mb-0">
                                                        <thead class="table-light">
                                                            <tr>
                                                                <th style="width:2.5rem;">#</th>
                                                                <th style="width:6rem;">Cluster</th>
                                                                <th>Item</th>
                                                                <th style="width:14rem;">Réponse</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            {% set itemList = q.questions.items|sort((a,b) => a.ordre_affichage <=> b.ordre_affichage) %}
                                                            {% for item in itemList %}
                                                                {% set answer = response.answers[item.id] ?? '—' %}
                                                                {% set selectedLabel = '—' %}
                                                                {% if answer != '—' %}
                                                                    {% for opt in item.options %}
                                                                        {% if opt.valeur ~ '' == answer ~ '' %}
                                                                            {% set selectedLabel = opt.code ~ ' — ' ~ opt.label %}
                                                                        {% endif %}
                                                                    {% endfor %}
                                                                {% endif %}
                                                                {% set badgeClass = clusterColors[item.sous_echelle] ?? 'bg-secondary-lt text-secondary' %}
                                                                <tr>
                                                                    <td class="text-muted">{{ item.ordre_affichage }}</td>
                                                                    <td>
                                                                        <span class="badge {{ badgeClass }}" style="font-size:.6rem;">
                                                                            {{ (clusterLabels[item.sous_echelle] ?? item.sous_echelle)|upper }}
                                                                        </span>
                                                                    </td>
                                                                    <td class="small">{{ item.texte }}</td>
                                                                    <td>
                                                                        {% if answer != '—' %}
                                                                            <span class="badge small
                                                                                {% if answer == '0' %}bg-success-lt text-success
                                                                                {% elseif answer == '1' %}bg-warning-lt text-warning
                                                                                {% elseif answer == '2' %}bg-orange-lt text-orange
                                                                                {% else %}bg-danger-lt text-danger{% endif %}">
                                                                                {{ selectedLabel }}
                                                                            </span>
                                                                        {% else %}
                                                                            <span class="text-muted">—</span>
                                                                        {% endif %}
                                                                    </td>
                                                                </tr>
                                                            {% endfor %}
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    {% endif %}{# end isComplete #}

                                    <div class="px-4 py-2 text-muted small d-flex gap-4 border-top">
                                        <span>Commencé : {{ response.startedAt ? response.startedAt|date('d/m/Y à H:i') : '—' }}</span>
                                        <span>Terminé : {{ response.completedAt ? response.completedAt|date('d/m/Y à H:i') : '—' }}</span>
                                    </div>

                                {# ══════════════════════════════════════════════
                                   DIVA 2.0 mode
                                   ══════════════════════════════════════════════ #}
                                {% elseif isDiva %}
                                    {% set dAns = response.answers ?? {} %}
                                    {% set divaSections = q.questions.sections %}

                                    {% if response.isComplete %}
                                    {# ── Score summary ── #}
                                    <div class="px-4 py-3 border-bottom">
                                        <h5 class="fw-bold mb-3" style="color:#2c5282;">Scores DIVA 2.0</h5>
                                        <div class="row g-3">
                                            {% for section in divaSections %}
                                            {% if section.has_periods %}
                                            {% set adultScore = dAns['_score_' ~ section.id ~ '_adult'] ?? '—' %}
                                            {% set childScore = dAns['_score_' ~ section.id ~ '_child'] ?? '—' %}
                                            <div class="col-md-6">
                                                <div class="diva-score-card h-100">
                                                    <div class="fw-bold mb-2" style="color:#2c5282;">{{ section.short_label }}</div>
                                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                                        <span class="text-muted small">Adulte (6 derniers mois)</span>
                                                        <div class="d-flex align-items-center gap-2">
                                                            <span class="fw-bold">{{ adultScore }} / {{ section.items|length }}</span>
                                                            {% if adultScore is not same as('—') %}
                                                            <span class="badge small {{ adultScore >= 6 ? 'diva-threshold-warn' : 'diva-threshold-ok' }}">
                                                                {{ adultScore >= 6 ? '⚠ Seuil atteint (≥6)' : '✓ Sous le seuil' }}
                                                            </span>
                                                            {% endif %}
                                                        </div>
                                                    </div>
                                                    {% if adultScore is not same as('—') %}
                                                    <div class="ens-cluster-bar mb-2">
                                                        <div class="ens-cluster-bar-fill {{ adultScore >= 6 ? 'ens-score-high' : 'ens-score-low' }}"
                                                             style="width:{{ (adultScore / section.items|length * 100)|round }}%"></div>
                                                    </div>
                                                    {% endif %}
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <span class="text-muted small">Enfance (5–12 ans)</span>
                                                        <div class="d-flex align-items-center gap-2">
                                                            <span class="fw-bold">{{ childScore }} / {{ section.items|length }}</span>
                                                            {% if childScore is not same as('—') %}
                                                            <span class="badge small {{ childScore >= 6 ? 'diva-threshold-warn' : 'diva-threshold-ok' }}">
                                                                {{ childScore >= 6 ? '⚠ Seuil atteint (≥6)' : '✓ Sous le seuil' }}
                                                            </span>
                                                            {% endif %}
                                                        </div>
                                                    </div>
                                                    {% if childScore is not same as('—') %}
                                                    <div class="ens-cluster-bar mt-1">
                                                        <div class="ens-cluster-bar-fill {{ childScore >= 6 ? 'ens-score-high' : 'ens-score-low' }}"
                                                             style="width:{{ (childScore / section.items|length * 100)|round }}%"></div>
                                                    </div>
                                                    {% endif %}
                                                </div>
                                            </div>
                                            {% else %}
                                            {# Fonctionnement section #}
                                            {% set funcScore = dAns['_score_' ~ section.id] ?? '—' %}
                                            <div class="col-md-12">
                                                <div class="diva-score-card">
                                                    <div class="fw-bold mb-2" style="color:#2c5282;">{{ section.short_label }}</div>
                                                    <div class="d-flex align-items-center gap-3 flex-wrap">
                                                        {% for item in section.items %}
                                                        {% set val = dAns[item.id] ?? null %}
                                                        <span class="badge {{ val == 'oui' ? 'bg-success-lt text-success' : (val == 'non' ? 'bg-secondary-lt text-secondary' : 'bg-light text-muted') }}">
                                                            {{ item.id }} : {{ val ?? '—' }}
                                                        </span>
                                                        {% endfor %}
                                                        {% if funcScore is not same as('—') %}
                                                        <span class="ms-auto fw-bold">{{ funcScore }} / {{ section.items|length }} domaine(s) impacté(s)</span>
                                                        <span class="badge small {{ funcScore >= 2 ? 'diva-threshold-warn' : 'diva-threshold-ok' }}">
                                                            {{ funcScore >= 2 ? '⚠ Retentissement ≥2 domaines' : '✓ < 2 domaines' }}
                                                        </span>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                            </div>
                                            {% endif %}
                                            {% endfor %}
                                        </div>

                                        {# DSM-IV proposal #}
                                        {% set inattAdult  = dAns['_score_inattention_adult']     ?? null %}
                                        {% set inattChild  = dAns['_score_inattention_child']     ?? null %}
                                        {% set hyperAdult  = dAns['_score_hyperactivite_adult']   ?? null %}
                                        {% set hyperChild  = dAns['_score_hyperactivite_child']   ?? null %}
                                        {% set funcDomains = dAns['_score_fonctionnement']        ?? null %}
                                        {% if inattAdult is not null and hyperAdult is not null %}
                                        <div class="mt-4 p-3 border rounded" style="background:#f7faff;border-color:#bee3f8!important;">
                                            <div class="fw-bold mb-2" style="color:#2c5282;">
                                                Proposition diagnostique DSM-IV
                                                <span class="text-muted fw-normal small">(à confirmer par le clinicien)</span>
                                            </div>
                                            <div class="row g-2 small">
                                                <div class="col-sm-6">
                                                    <div class="text-muted">Inattention adulte ≥6 :</div>
                                                    <strong class="{{ inattAdult >= 6 ? 'text-danger' : 'text-success' }}">{{ inattAdult >= 6 ? 'OUI (' ~ inattAdult ~ '/9)' : 'NON (' ~ inattAdult ~ '/9)' }}</strong>
                                                </div>
                                                <div class="col-sm-6">
                                                    <div class="text-muted">Hyperactivité adulte ≥6 :</div>
                                                    <strong class="{{ hyperAdult >= 6 ? 'text-danger' : 'text-success' }}">{{ hyperAdult >= 6 ? 'OUI (' ~ hyperAdult ~ '/9)' : 'NON (' ~ hyperAdult ~ '/9)' }}</strong>
                                                </div>
                                                {% if inattChild is not null %}
                                                <div class="col-sm-6">
                                                    <div class="text-muted">Inattention enfance ≥6 :</div>
                                                    <strong class="{{ inattChild >= 6 ? 'text-danger' : 'text-success' }}">{{ inattChild >= 6 ? 'OUI (' ~ inattChild ~ '/9)' : 'NON (' ~ inattChild ~ '/9)' }}</strong>
                                                </div>
                                                {% endif %}
                                                {% if hyperChild is not null %}
                                                <div class="col-sm-6">
                                                    <div class="text-muted">Hyperactivité enfance ≥6 :</div>
                                                    <strong class="{{ hyperChild >= 6 ? 'text-danger' : 'text-success' }}">{{ hyperChild >= 6 ? 'OUI (' ~ hyperChild ~ '/9)' : 'NON (' ~ hyperChild ~ '/9)' }}</strong>
                                                </div>
                                                {% endif %}
                                                {% if funcDomains is not null %}
                                                <div class="col-sm-6">
                                                    <div class="text-muted">Retentissement ≥2 domaines :</div>
                                                    <strong class="{{ funcDomains >= 2 ? 'text-danger' : 'text-success' }}">{{ funcDomains >= 2 ? 'OUI (' ~ funcDomains ~ '/5)' : 'NON (' ~ funcDomains ~ '/5)' }}</strong>
                                                </div>
                                                {% endif %}
                                            </div>
                                            {% set typeLabel = '' %}
                                            {% if inattAdult >= 6 and hyperAdult >= 6 %}
                                                {% set typeLabel = 'Type Combiné (314.01)' %}
                                            {% elseif inattAdult >= 6 %}
                                                {% set typeLabel = 'Inattention prédominante (314.00)' %}
                                            {% elseif hyperAdult >= 6 %}
                                                {% set typeLabel = 'Hyperactivité/Impulsivité prédominante (314.01)' %}
                                            {% else %}
                                                {% set typeLabel = 'Critères adultes non atteints' %}
                                            {% endif %}
                                            <div class="mt-2 pt-2 border-top fw-bold" style="color:#2c5282;">
                                                Type proposé : {{ typeLabel }}
                                                {% if inattChild >= 6 or hyperChild >= 6 %}
                                                <span class="text-muted fw-normal small ms-2">— Critères enfance présents → persistance vie entière possible</span>
                                                {% endif %}
                                            </div>
                                        </div>
                                        {% endif %}
                                    </div>
                                    {% endif %}{# end isComplete #}

                                    {# ── Item-by-item detail ── #}
                                    <div class="px-4 py-3">
                                        <div class="accordion accordion-flush" id="diva-detail-{{ i }}">
                                        {% for section in divaSections %}
                                        <div class="accordion-item border rounded mb-2">
                                            <h2 class="accordion-header">
                                                <button class="accordion-button collapsed fw-semibold" type="button"
                                                        data-bs-toggle="collapse"
                                                        data-bs-target="#diva-sec-{{ i }}-{{ section.id }}"
                                                        style="color:#2c5282;">
                                                    {{ section.label }}
                                                </button>
                                            </h2>
                                            <div id="diva-sec-{{ i }}-{{ section.id }}" class="accordion-collapse collapse">
                                                <div class="accordion-body p-0">
                                                    <table class="table table-sm table-vcenter mb-0">
                                                        <thead class="table-light">
                                                            <tr>
                                                                <th style="width:3.5rem;">Code</th>
                                                                <th>Critère</th>
                                                                {% if section.has_periods %}
                                                                <th class="text-center" style="width:5.5rem;">Adulte</th>
                                                                <th class="text-center" style="width:5.5rem;">Enfance</th>
                                                                {% else %}
                                                                <th class="text-center" style="width:5.5rem;">Réponse</th>
                                                                {% endif %}
                                                                <th>Commentaires</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            {% for item in section.items %}
                                                            {% if section.has_periods %}
                                                                {% set aVal = dAns[item.id ~ '_adult'] ?? null %}
                                                                {% set cVal = dAns[item.id ~ '_child'] ?? null %}
                                                                {% set aComment = dAns[item.id ~ '_adult_comment'] ?? '' %}
                                                                {% set cComment = dAns[item.id ~ '_child_comment'] ?? '' %}
                                                                <tr>
                                                                    <td class="fw-bold text-muted">{{ item.id }}</td>
                                                                    <td class="small">{{ item.text }}</td>
                                                                    <td class="text-center">
                                                                        {% if aVal == 'oui' %}<span class="diva-yn-oui">OUI</span>
                                                                        {% elseif aVal == 'non' %}<span class="diva-yn-non">NON</span>
                                                                        {% else %}<span class="diva-yn-dash">—</span>{% endif %}
                                                                    </td>
                                                                    <td class="text-center">
                                                                        {% if cVal == 'oui' %}<span class="diva-yn-oui">OUI</span>
                                                                        {% elseif cVal == 'non' %}<span class="diva-yn-non">NON</span>
                                                                        {% else %}<span class="diva-yn-dash">—</span>{% endif %}
                                                                    </td>
                                                                    <td class="small text-muted">
                                                                        {% if aComment %}<div><em>Adulte :</em> {{ aComment }}</div>{% endif %}
                                                                        {% if cComment %}<div><em>Enfance :</em> {{ cComment }}</div>{% endif %}
                                                                    </td>
                                                                </tr>
                                                            {% else %}
                                                                {% set fVal     = dAns[item.id] ?? null %}
                                                                {% set fComment = dAns[item.id ~ '_comment'] ?? '' %}
                                                                <tr>
                                                                    <td class="fw-bold text-muted">{{ item.id }}</td>
                                                                    <td class="small">{{ item.text }}</td>
                                                                    <td class="text-center">
                                                                        {% if fVal == 'oui' %}<span class="diva-yn-oui">OUI</span>
                                                                        {% elseif fVal == 'non' %}<span class="diva-yn-non">NON</span>
                                                                        {% else %}<span class="diva-yn-dash">—</span>{% endif %}
                                                                    </td>
                                                                    <td class="small text-muted">
                                                                        {% if fComment %}{{ fComment }}{% endif %}
                                                                    </td>
                                                                </tr>
                                                            {% endif %}
                                                            {% endfor %}
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                        {% endfor %}
                                        </div>
                                    </div>

                                    <div class="px-4 py-2 text-muted small d-flex gap-4 border-top">
                                        <span>Commencé : {{ response.startedAt ? response.startedAt|date('d/m/Y à H:i') : '—' }}</span>
                                        <span>Terminé : {{ response.completedAt ? response.completedAt|date('d/m/Y à H:i') : '—' }}</span>
                                    </div>

                                {# ══════════════════════════════════════════════
                                   STANDARD / RICH mode (HAD, Brown ENF, etc.)
                                   ══════════════════════════════════════════════ #}
                                {% elseif q.questions.items is defined %}
                                    {% if q.description %}
                                        <div class="px-4 pt-3 text-muted small">{{ q.description }}</div>
                                    {% endif %}

                                    {# Build cluster color palette #}
                                    {% set palette = ['bg-warning-lt text-warning','bg-success-lt text-success','bg-blue-lt text-blue','bg-azure-lt text-azure','bg-teal-lt text-teal','bg-pink-lt text-pink','bg-orange-lt text-orange','bg-indigo-lt text-indigo'] %}
                                    {% set clusterLabels = {} %}
                                    {% set clusterColors = {} %}
                                    {% if q.questions.sous_echelles is defined %}
                                        {% for se in q.questions.sous_echelles %}
                                            {% set clusterLabels = clusterLabels|merge({(se.id): se.label}) %}
                                            {% set clusterColors = clusterColors|merge({(se.id): palette[loop.index0 % palette|length]}) %}
                                        {% endfor %}
                                    {% endif %}

                                    <table class="table table-sm table-vcenter mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width: 3rem;">#</th>
                                                <th>Question</th>
                                                <th>Réponse</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% set itemList = q.questions.items|sort((a, b) => a.ordre_affichage <=> b.ordre_affichage) %}
                                            {% for item in itemList %}
                                                {% set answer = response.answers[item.id] ?? '—' %}
                                                {% set selectedLabel = '—' %}
                                                {% if answer != '—' %}
                                                    {% for opt in item.options %}
                                                        {% if opt.valeur ~ '' == answer ~ '' %}
                                                            {% set selectedLabel = (opt.code is defined ? opt.code ~ ' — ' : '') ~ opt.label ~ ' (' ~ opt.valeur ~ ')' %}
                                                        {% endif %}
                                                    {% endfor %}
                                                {% endif %}
                                                <tr>
                                                    <td class="text-muted">{{ item.ordre_affichage }}</td>
                                                    <td>
                                                        {% set badgeClass = clusterColors[item.sous_echelle] ?? 'bg-secondary-lt text-secondary' %}
                                                        {% set badgeShort = (clusterLabels[item.sous_echelle] ?? item.sous_echelle)|slice(0,4)|upper %}
                                                        <span class="badge {{ badgeClass }} me-1" style="font-size:.6rem;">{{ badgeShort }}</span>
                                                        {{ item.texte }}
                                                    </td>
                                                    <td>{{ selectedLabel }}</td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                        {% if response.score is not null %}
                                            <tfoot class="table-light">
                                                {% if q.questions.sous_echelles is defined %}
                                                    {% for se in q.questions.sous_echelles %}
                                                        {% set seScore = response.answers['_score_' ~ se.id] ?? '—' %}
                                                        <tr>
                                                            <td colspan="2" class="text-end fw-bold">Score {{ se.label }}</td>
                                                            <td class="fw-bold text-blue">{{ seScore }} / {{ se.score_max }}</td>
                                                        </tr>
                                                    {% endfor %}
                                                {% endif %}
                                                <tr>
                                                    <td colspan="2" class="text-end fw-bold">Score total</td>
                                                    <td class="fw-bold text-blue">{{ response.score }}</td>
                                                </tr>
                                            </tfoot>
                                        {% endif %}
                                    </table>

                                    <div class="px-4 py-2 text-muted small d-flex gap-4">
                                        <span>Commencé : {{ response.startedAt ? response.startedAt|date('d/m/Y à H:i') : '—' }}</span>
                                        <span>Terminé : {{ response.completedAt ? response.completedAt|date('d/m/Y à H:i') : '—' }}</span>
                                    </div>

                                {% else %}
                                    {# Legacy simple format #}
                                    {% if q.description %}
                                        <div class="px-4 pt-3 text-muted small">{{ q.description }}</div>
                                    {% endif %}
                                    <table class="table table-sm table-vcenter mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width: 3rem;">#</th>
                                                <th>Question</th>
                                                <th>Réponse</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for idx, question in q.questions %}
                                                {% set answer = response.answers[idx ~ ''] ?? '—' %}
                                                <tr>
                                                    <td class="text-muted">{{ loop.index }}</td>
                                                    <td>{{ question.text ?? question.label ?? '?' }}</td>
                                                    <td>
                                                        {% if answer is iterable %}
                                                            {{ answer|join(', ') }}
                                                        {% else %}
                                                            {{ answer }}
                                                        {% endif %}
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                    <div class="px-4 py-2 text-muted small d-flex gap-4">
                                        <span>Commencé : {{ response.startedAt ? response.startedAt|date('d/m/Y à H:i') : '—' }}</span>
                                        <span>Terminé : {{ response.completedAt ? response.completedAt|date('d/m/Y à H:i') : '—' }}</span>
                                    </div>
                                {% endif %}

                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>

{# ══════════════════════════════════════════════════════════════
   Brown ENS — Comparaison multi-passations (si > 1 complète)
   ══════════════════════════════════════════════════════════════ #}
{% set brownEnsResponses = [] %}
{% for r in responses %}
    {% if r.questionnaire.slug == 'brown_ens_8_12' and r.isComplete %}
        {% set brownEnsResponses = brownEnsResponses|merge([r]) %}
    {% endif %}
{% endfor %}

{% if brownEnsResponses|length > 1 %}
<div class="card mt-4 mb-5">
    <div class="card-header fw-bold text-white" style="background:#4A9A9A;">
        <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-chart-line me-2" width="20" height="20" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><polyline points="4 19 8 13 12 15 16 10 20 14"/><line x1="4" y1="4" x2="4" y2="20"/><line x1="4" y1="20" x2="20" y2="20"/></svg>
        Évolution — Brown ENS 8-12 ({{ brownEnsResponses|length }} passations)
    </div>
    <div class="card-body">
        {% set firstQ = brownEnsResponses[0].questionnaire %}
        <div class="table-responsive">
            <table class="table table-sm table-bordered mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Cluster</th>
                        {% for r in brownEnsResponses %}
                        <th class="text-center" style="min-width:130px;">
                            {{ r.completedAt ? r.completedAt|date('d/m/Y') : r.startedAt|date('d/m/Y') }}
                            {% if r.answers['_meta_evaluateur'] is defined %}
                                <br><small class="text-muted fw-normal">{{ r.answers['_meta_evaluateur'] }}</small>
                            {% endif %}
                        </th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% if firstQ.questions.sous_echelles is defined %}
                        {% set totalMax = 0 %}
                        {% for se in firstQ.questions.sous_echelles %}
                            {% set totalMax = totalMax + se.score_max %}
                            <tr>
                                <td class="fw-semibold">{{ se.label }}</td>
                                {% for r in brownEnsResponses %}
                                    {% set seScore = r.answers['_score_' ~ se.id] ?? 0 %}
                                    {% set pct = se.score_max > 0 ? (seScore / se.score_max * 100)|round : 0 %}
                                    <td class="text-center">
                                        <span class="fw-bold">{{ seScore }}</span>
                                        <span class="text-muted small">/{{ se.score_max }}</span>
                                        <br>
                                        <span class="badge small
                                            {% if pct <= 33 %}ens-badge-low
                                            {% elseif pct <= 66 %}ens-badge-mid
                                            {% else %}ens-badge-high{% endif %}">
                                            {{ pct }}%
                                        </span>
                                    </td>
                                {% endfor %}
                            </tr>
                        {% endfor %}
                        <tr class="table-light fw-bold">
                            <td>TOTAL</td>
                            {% for r in brownEnsResponses %}
                                {% set totalScore = 0 %}
                                {% for se in firstQ.questions.sous_echelles %}
                                    {% set totalScore = totalScore + (r.answers['_score_' ~ se.id] ?? 0) %}
                                {% endfor %}
                                {% set totalPct = totalMax > 0 ? (totalScore / totalMax * 100)|round : 0 %}
                                <td class="text-center">
                                    <span>{{ totalScore }}</span>
                                    <span class="text-muted small">/{{ totalMax }}</span>
                                    <br>
                                    <span class="badge small
                                        {% if totalPct <= 33 %}ens-badge-low
                                        {% elseif totalPct <= 66 %}ens-badge-mid
                                        {% else %}ens-badge-high{% endif %}">
                                        {{ totalPct }}%
                                    </span>
                                </td>
                            {% endfor %}
                        </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% else %}
<div class="mb-4"></div>
{% endif %}

{# ══════════════════════════════════════════════════════════════
   Brown ENF Parents — Comparaison multi-passations (si > 1 complète)
   ══════════════════════════════════════════════════════════════ #}
{% set brownParentsResponses = [] %}
{% for r in responses %}
    {% if r.questionnaire.slug == 'brown_enf_8_12_parents' and r.isComplete %}
        {% set brownParentsResponses = brownParentsResponses|merge([r]) %}
    {% endif %}
{% endfor %}

{% if brownParentsResponses|length > 1 %}
<div class="card mt-4 mb-5">
    <div class="card-header fw-bold text-white" style="background:#1a6fa8;">
        <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-chart-line me-2" width="20" height="20" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><polyline points="4 19 8 13 12 15 16 10 20 14"/><line x1="4" y1="4" x2="4" y2="20"/><line x1="4" y1="20" x2="20" y2="20"/></svg>
        Évolution — Brown ENF 8-12 Parents ({{ brownParentsResponses|length }} passations)
    </div>
    <div class="card-body">
        {% set firstQ = brownParentsResponses[0].questionnaire %}
        <div class="table-responsive">
            <table class="table table-sm table-bordered mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Cluster</th>
                        {% for r in brownParentsResponses %}
                        <th class="text-center" style="min-width:130px;">
                            {{ r.completedAt ? r.completedAt|date('d/m/Y') : r.startedAt|date('d/m/Y') }}
                            {% if r.answers['_meta_evaluateur'] is defined and r.answers['_meta_evaluateur'] is not empty %}
                                <br><small class="text-muted fw-normal">{{ r.answers['_meta_evaluateur'] }}</small>
                                {% if r.answers['_meta_lien_parente'] is defined and r.answers['_meta_lien_parente'] is not empty %}
                                    <br><small class="text-muted fw-normal">({{ r.answers['_meta_lien_parente'] }})</small>
                                {% endif %}
                            {% else %}
                                {% set evPrenom = r.answers['_meta_evaluateur_prenom'] ?? '' %}
                                {% set evNom = r.answers['_meta_evaluateur_nom'] ?? '' %}
                                {% if evNom is not empty %}
                                    <br><small class="text-muted fw-normal">{{ evPrenom ~ ' ' ~ evNom }}</small>
                                {% endif %}
                            {% endif %}
                        </th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% if firstQ.questions.sous_echelles is defined %}
                        {% set totalMax = 0 %}
                        {% for se in firstQ.questions.sous_echelles %}
                            {% set totalMax = totalMax + se.score_max %}
                            <tr>
                                <td class="fw-semibold">{{ se.label }}</td>
                                {% for r in brownParentsResponses %}
                                    {% set seScore = r.answers['_score_' ~ se.id] ?? 0 %}
                                    {% set pct = se.score_max > 0 ? (seScore / se.score_max * 100)|round : 0 %}
                                    <td class="text-center">
                                        <span class="fw-bold">{{ seScore }}</span>
                                        <span class="text-muted small">/{{ se.score_max }}</span>
                                        <br>
                                        <span class="badge small
                                            {% if pct <= 33 %}ens-badge-low
                                            {% elseif pct <= 66 %}ens-badge-mid
                                            {% else %}ens-badge-high{% endif %}">
                                            {{ pct }}%
                                        </span>
                                    </td>
                                {% endfor %}
                            </tr>
                        {% endfor %}
                        <tr class="table-light fw-bold">
                            <td>TOTAL</td>
                            {% for r in brownParentsResponses %}
                                {% set totalScore = 0 %}
                                {% for se in firstQ.questions.sous_echelles %}
                                    {% set totalScore = totalScore + (r.answers['_score_' ~ se.id] ?? 0) %}
                                {% endfor %}
                                {% set totalPct = totalMax > 0 ? (totalScore / totalMax * 100)|round : 0 %}
                                <td class="text-center">
                                    <span>{{ totalScore }}</span>
                                    <span class="text-muted small">/{{ totalMax }}</span>
                                    <br>
                                    <span class="badge small
                                        {% if totalPct <= 33 %}ens-badge-low
                                        {% elseif totalPct <= 66 %}ens-badge-mid
                                        {% else %}ens-badge-high{% endif %}">
                                        {{ totalPct }}%
                                    </span>
                                </td>
                            {% endfor %}
                        </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% else %}
<div class="mb-5"></div>
{% endif %}

{# ── Identifiants de connexion ── #}
<div class="container-xl mb-5">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-key me-2 text-blue" width="20" height="20" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <circle cx="8" cy="15" r="4"/>
                    <line x1="10.85" y1="12.15" x2="19" y2="4"/>
                    <line x1="18" y1="5" x2="20" y2="7"/>
                    <line x1="15" y1="8" x2="17" y2="10"/>
                </svg>
                Identifiants de connexion
            </h3>
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-center">
                <div class="col-md-6">
                    <div class="mb-1 text-muted small">Adresse email</div>
                    <div class="fw-semibold">{{ patient.email }}</div>
                </div>
                <div class="col-md-6">
                    <div class="mb-1 text-muted small">Mot de passe</div>
                    <div class="fw-semibold">••••••••</div>
                </div>
            </div>
        </div>
        <div class="card-footer">
            <a href="{{ path('app_admin_patient_credentials', {id: patient.id}) }}" class="btn btn-outline-primary btn-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-edit me-1" width="16" height="16" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
                    <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z"/>
                </svg>
                Modifier les identifiants
            </a>
        </div>
    </div>
</div>

{# ── Zone de suppression définitive ── #}
<div class="container-xl mb-5">
    <div class="card" style="border: 2px solid var(--tblr-danger);">
        <div class="card-header bg-danger-lt">
            <h3 class="card-title text-danger">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-alert-triangle me-2" width="20" height="20" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M12 9v4m0 4h.01"/>
                    <path d="M5.07 19h13.86a2 2 0 0 0 1.75 -2.97l-6.93 -12.02a2 2 0 0 0 -3.5 0l-6.93 12.02a2 2 0 0 0 1.75 2.97z"/>
                </svg>
                Suppression définitive du dossier
            </h3>
        </div>
        <div class="card-body">
            <p class="text-muted mb-4">
                Cette action supprimera définitivement le compte du patient,
                son anamnèse, et tous ses questionnaires. Elle est conforme aux obligations
                RGPD de droit à l'effacement (Art. 17). Elle ne peut pas être annulée.
            </p>
            <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deletePatientModal">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-user-x me-1" width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0"/>
                    <path d="M6 21v-2a4 4 0 0 1 4 -4h3.5"/>
                    <path d="M22 22l-5 -5"/>
                    <path d="M17 22l5 -5"/>
                </svg>
                Supprimer le dossier patient
            </button>
        </div>
    </div>
</div>

{# ── Modale de confirmation ── #}
<div class="modal modal-blur fade" id="deletePatientModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger">
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-alert-circle me-2" width="20" height="20" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <circle cx="12" cy="12" r="9"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    Supprimer le dossier de {{ patient.fullName }}
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body text-muted">
                Toutes les données de ce patient seront effacées de la base de données.
                Cette action est définitive et conforme au droit à l'effacement (RGPD Art. 17).
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <form method="POST" action="{{ path('app_admin_patient_delete', {id: patient.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_patient_' ~ patient.id) }}">
                    <button type="submit" class="btn btn-danger">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-user-x me-1" width="16" height="16" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                            <path d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0"/>
                            <path d="M6 21v-2a4 4 0 0 1 4 -4h3.5"/>
                            <path d="M22 22l-5 -5"/>
                            <path d="M17 22l5 -5"/>
                        </svg>
                        Confirmer la suppression définitive
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
