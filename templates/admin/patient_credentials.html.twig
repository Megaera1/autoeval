{% extends 'base.html.twig' %}

{% block title %}Identifiants — {{ patient.fullName }} — AutoEval{% endblock %}

{% block navbar %}
<header class="navbar navbar-expand-md navbar-dark bg-blue d-print-none">
    <div class="container-xl">
        <a href="{{ path('app_admin_dashboard') }}" class="navbar-brand navbar-brand-autodark">
            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-brain me-2" width="28" height="28" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M15.5 13a3.5 3.5 0 0 0 -3.5 3.5v1a3.5 3.5 0 0 0 7 0v-1.8"/>
                <path d="M8.5 13a3.5 3.5 0 0 1 3.5 3.5v1a3.5 3.5 0 0 1 -7 0v-1.8"/>
                <path d="M17.5 16a3.5 3.5 0 0 0 0 -7h-.5"/>
                <path d="M19 9.3v-2.8a3.5 3.5 0 0 0 -7 0"/>
                <path d="M6.5 16a3.5 3.5 0 0 1 0 -7h.5"/>
                <path d="M5 9.3v-2.8a3.5 3.5 0 0 1 7 0v10"/>
            </svg>
            <strong>AutoEval</strong>
        </a>
        <div class="navbar-nav ms-auto d-flex align-items-center gap-3">
            <span class="text-white small">Neuropsychologue</span>
            <a href="{{ path('app_logout') }}" class="btn btn-outline-light btn-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-logout me-1" width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M14 8v-2a2 2 0 0 0 -2 -2h-7a2 2 0 0 0 -2 2v12a2 2 0 0 0 2 2h7a2 2 0 0 0 2 -2v-2"/>
                    <path d="M9 12h12l-3 -3"/><path d="M18 15l3 -3"/>
                </svg>
                Déconnexion
            </a>
        </div>
    </div>
</header>
{% endblock %}

{% block body %}
<div class="page-header mt-3">
    <div class="container-xl">
        <div class="row align-items-center">
            <div class="col-auto">
                <ol class="breadcrumb" aria-label="breadcrumbs">
                    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">Tableau de bord</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('app_admin_patient_profile', {id: patient.id}) }}">{{ patient.fullName }}</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Identifiants</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">

                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible mb-3">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                {% endfor %}

                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-key me-2 text-blue" width="20" height="20" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <circle cx="8" cy="15" r="4"/>
                                <line x1="10.85" y1="12.15" x2="19" y2="4"/>
                                <line x1="18" y1="5" x2="20" y2="7"/>
                                <line x1="15" y1="8" x2="17" y2="10"/>
                            </svg>
                            Identifiants de connexion — {{ patient.fullName }}
                        </h3>
                    </div>

                    <div class="card-body">
                        <div class="alert alert-warning mb-4">
                            <div class="d-flex align-items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-alert-triangle me-2" width="20" height="20" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                    <path d="M12 9v4m0 4h.01"/>
                                    <path d="M5.07 19h13.86a2 2 0 0 0 1.75 -2.97l-6.93 -12.02a2 2 0 0 0 -3.5 0l-6.93 12.02a2 2 0 0 0 1.75 2.97z"/>
                                </svg>
                                <div>Toute modification des identifiants sera appliquée immédiatement. Si vous changez le mot de passe, informez le patient.</div>
                            </div>
                        </div>

                        {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

                        <div class="mb-3">
                            {{ form_label(form.email, null, {label_attr: {class: 'form-label required'}}) }}
                            {{ form_widget(form.email, {attr: {class: 'form-control' ~ (form.email.vars.errors|length ? ' is-invalid' : '')}}) }}
                            {{ form_errors(form.email) }}
                        </div>

                        <hr class="my-4">

                        <h4 class="mb-3 text-muted fs-6 text-uppercase fw-bold">Modifier le mot de passe</h4>

                        <div class="mb-3">
                            {{ form_label(form.newPassword, null, {label_attr: {class: 'form-label'}}) }}
                            {{ form_widget(form.newPassword, {attr: {class: 'form-control' ~ (form.newPassword.vars.errors|length ? ' is-invalid' : '')}}) }}
                            {{ form_errors(form.newPassword) }}
                            <small class="form-hint">Minimum 8 caractères. Laisser vide pour conserver le mot de passe actuel.</small>
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.newPasswordConfirm, null, {label_attr: {class: 'form-label'}}) }}
                            {{ form_widget(form.newPasswordConfirm, {attr: {class: 'form-control' ~ (form.newPasswordConfirm.vars.errors|length ? ' is-invalid' : '')}}) }}
                            {{ form_errors(form.newPasswordConfirm) }}
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-device-floppy me-1" width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                    <path d="M6 4h10l4 4v10a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2v-12a2 2 0 0 1 2 -2"/>
                                    <circle cx="12" cy="14" r="2"/>
                                    <polyline points="14 4 14 8 8 8 8 4"/>
                                </svg>
                                Enregistrer
                            </button>
                            <a href="{{ path('app_admin_patient_profile', {id: patient.id}) }}" class="btn btn-outline-secondary">Annuler</a>
                        </div>

                        {{ form_end(form) }}
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
{% endblock %}
