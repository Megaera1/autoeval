{% extends 'base.html.twig' %}

{% block title %}Tableau de bord — AutoEval{% endblock %}

{% block navbar %}
<header class="navbar navbar-expand-md navbar-dark bg-blue d-print-none">
    <div class="container-xl">
        <a href="{{ path('app_admin_dashboard') }}" class="navbar-brand navbar-brand-autodark">
            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-brain me-2" width="28" height="28" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M15.5 13a3.5 3.5 0 0 0 -3.5 3.5v1a3.5 3.5 0 0 0 7 0v-1.8"/>
                <path d="M8.5 13a3.5 3.5 0 0 1 3.5 3.5v1a3.5 3.5 0 0 1 -7 0v-1.8"/>
                <path d="M17.5 16a3.5 3.5 0 0 0 0 -7h-.5"/>
                <path d="M19 9.3v-2.8a3.5 3.5 0 0 0 -7 0"/>
                <path d="M6.5 16a3.5 3.5 0 0 1 0 -7h.5"/>
                <path d="M5 9.3v-2.8a3.5 3.5 0 0 1 7 0v10"/>
            </svg>
            <strong>AutoEval</strong>
        </a>

        <div class="navbar-nav ms-auto d-flex align-items-center gap-3">
            <span class="text-white small">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-stethoscope me-1" width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M6 4h-1a2 2 0 0 0 -2 2v3.5h0a5.5 5.5 0 0 0 11 0v-3.5a2 2 0 0 0 -2 -2h-1"/>
                    <path d="M8 15a6 6 0 1 0 12 0v-3"/>
                    <path d="M11 3v2"/><path d="M6 3v2"/>
                    <circle cx="20" cy="10" r="2"/>
                </svg>
                Neuropsychologue
            </span>
            <a href="{{ path('app_logout') }}" class="btn btn-outline-light btn-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-logout me-1" width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M14 8v-2a2 2 0 0 0 -2 -2h-7a2 2 0 0 0 -2 2v12a2 2 0 0 0 2 2h7a2 2 0 0 0 2 -2v-2"/>
                    <path d="M9 12h12l-3 -3"/><path d="M18 15l3 -3"/>
                </svg>
                Déconnexion
            </a>
        </div>
    </div>
</header>
{% endblock %}

{% block body %}
<div class="page-header mt-4">
    <div class="row align-items-center">
        <div class="col">
            <h2 class="page-title">Tableau de bord</h2>
            <div class="text-muted mt-1">Vue d'ensemble des dossiers patients</div>
        </div>
    </div>
</div>

{# Tableau des patients #}
<div class="card mt-4">
    <div class="card-header">
        <h3 class="card-title">
            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-users me-2" width="20" height="20" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M3 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                <path d="M21 21v-2a4 4 0 0 0 -3 -3.85"/>
            </svg>
            Liste des patients
        </h3>
    </div>

    <div class="card-body border-bottom pb-3">
        <form method="GET" action="{{ path('app_admin_dashboard') }}" class="d-flex gap-2 flex-wrap">
            <input type="search" name="search" value="{{ search }}"
                   class="form-control" style="min-width:200px;flex:1;"
                   placeholder="Rechercher par nom, prénom ou email…"
                   aria-label="Rechercher un patient">
            <select name="sort" class="form-select" style="width:auto;" aria-label="Ordre de tri">
                <option value="date_desc" {{ sort == 'date_desc' ? 'selected' }}>Plus récents</option>
                <option value="date_asc"  {{ sort == 'date_asc'  ? 'selected' }}>Plus anciens</option>
                <option value="name_asc"  {{ sort == 'name_asc'  ? 'selected' }}>Nom (A–Z)</option>
                <option value="name_desc" {{ sort == 'name_desc' ? 'selected' }}>Nom (Z–A)</option>
            </select>
            <button type="submit" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-search" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <circle cx="10" cy="10" r="7"/>
                    <line x1="21" y1="21" x2="15" y2="15"/>
                </svg>
                Rechercher
            </button>
            {% if search %}
            <a href="{{ path('app_admin_dashboard', {sort: sort}) }}" class="btn btn-outline-secondary" title="Effacer la recherche">✕</a>
            {% endif %}
        </form>
        {% if search %}
        <div class="text-muted small mt-2">
            {{ patientRows|length }} résultat{{ patientRows|length != 1 ? 's' : '' }} pour « {{ search }} »
        </div>
        {% endif %}
    </div>

    {% if patientRows is empty %}
        <div class="card-body text-muted text-center py-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-mood-empty mb-2" width="40" height="40" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <circle cx="12" cy="12" r="9"/>
                <line x1="9" y1="10" x2="9.01" y2="10"/>
                <line x1="15" y1="10" x2="15.01" y2="10"/>
                <line x1="9" y1="15" x2="15" y2="15"/>
            </svg>
            <div>Aucun patient inscrit pour le moment.</div>
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-vcenter card-table">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th>Email</th>
                        <th>Inscription</th>
                        <th class="w-1"></th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in patientRows %}
                        {% set patient = row.patient %}
                        <tr>
                            <td class="fw-bold">{{ patient.lastName }}</td>
                            <td>{{ patient.firstName }}</td>
                            <td class="text-muted">{{ patient.email }}</td>
                            <td class="text-muted">
                                {{ patient.createdAt ? patient.createdAt|date('d/m/Y') : '—' }}
                            </td>
                            <td>
                                <a href="{{ path('app_admin_patient_profile', {id: patient.id}) }}"
                                   class="btn btn-sm btn-primary">
                                    Voir le profil
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
