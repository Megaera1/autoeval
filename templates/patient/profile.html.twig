{% extends 'base.html.twig' %}

{% block title %}Mon profil — AutoEval{% endblock %}

{% block navbar %}
<header class="navbar navbar-expand-md navbar-patient d-print-none">
    <div class="container-xl">
        <a href="{{ path('app_home') }}" class="navbar-brand navbar-brand-autodark">
            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-brain me-2" width="28" height="28" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M15.5 13a3.5 3.5 0 0 0 -3.5 3.5v1a3.5 3.5 0 0 0 7 0v-1.8"/>
                <path d="M8.5 13a3.5 3.5 0 0 1 3.5 3.5v1a3.5 3.5 0 0 1 -7 0v-1.8"/>
                <path d="M17.5 16a3.5 3.5 0 0 0 0 -7h-.5"/>
                <path d="M19 9.3v-2.8a3.5 3.5 0 0 0 -7 0"/>
                <path d="M6.5 16a3.5 3.5 0 0 1 0 -7h.5"/>
                <path d="M5 9.3v-2.8a3.5 3.5 0 0 1 7 0v10"/>
            </svg>
            <strong>AutoEval</strong>
        </a>

        <div class="navbar-nav ms-auto d-flex align-items-center gap-3">
            <span class="text-white">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-user me-1" width="20" height="20" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <circle cx="12" cy="7" r="4"/>
                    <path d="M6 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2"/>
                </svg>
                {{ app.user.firstName }}
            </span>
            <a href="{{ path('app_logout') }}" class="btn btn-primary btn-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-logout me-1" width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M14 8v-2a2 2 0 0 0 -2 -2h-7a2 2 0 0 0 -2 2v12a2 2 0 0 0 2 2h7a2 2 0 0 0 2 -2v-2"/>
                    <path d="M9 12h12l-3 -3"/>
                    <path d="M18 15l3 -3"/>
                </svg>
                Déconnexion
            </a>
        </div>
    </div>
</header>
{% endblock %}

{% block body %}
<div class="page-header mt-4">
    <div class="row align-items-center">
        <div class="col">
            <h2 class="page-title">Mon profil</h2>
            <div class="text-muted mt-1">Gérez vos informations personnelles et votre mot de passe</div>
        </div>
    </div>
</div>

<div class="row mt-4">

    {# ── Navigation latérale ── #}
    <div class="col-md-3 mb-4">

        {# Avatar initiales #}
        <div class="card mb-3 text-center">
            <div class="card-body py-4">
                <span class="avatar avatar-xl rounded-circle mb-3"
                      style="background-color: #2c7be5; color: #fff; font-size: 1.4rem; font-weight: 700;">
                    {{ user.firstName|slice(0,1)|upper }}{{ user.lastName|slice(0,1)|upper }}
                </span>
                <div class="fw-bold">{{ user.firstName }} {{ user.lastName }}</div>
                <div class="text-muted small">{{ user.email }}</div>
            </div>
        </div>

        {# Navigation latérale #}
        <div class="card">
            <div class="card-body p-2">
                <ul class="nav nav-pills flex-column gap-1">
                    <li class="nav-item">
                        <a href="{{ path('app_patient_dashboard') }}" class="nav-link">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-layout-dashboard me-2" width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <rect x="3" y="3" width="7" height="9"/>
                                <rect x="14" y="3" width="7" height="5"/>
                                <rect x="14" y="12" width="7" height="9"/>
                                <rect x="3" y="16" width="7" height="5"/>
                            </svg>
                            Tableau de bord
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_patient_anamnesis') }}" class="nav-link">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-file-text me-2" width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <path d="M14 3v4a1 1 0 0 0 1 1h4"/>
                                <path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z"/>
                                <line x1="9" y1="9" x2="10" y2="9"/>
                                <line x1="9" y1="13" x2="15" y2="13"/>
                                <line x1="9" y1="17" x2="15" y2="17"/>
                            </svg>
                            Mon anamnèse
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_patient_questionnaires') }}" class="nav-link">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-clipboard-list me-2" width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <path d="M9 5h-2a2 2 0 0 0 -2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-12a2 2 0 0 0 -2 -2h-2"/>
                                <rect x="9" y="3" width="6" height="4" rx="2"/>
                                <line x1="9" y1="12" x2="9.01" y2="12"/>
                                <line x1="13" y1="12" x2="15" y2="12"/>
                                <line x1="9" y1="16" x2="9.01" y2="16"/>
                                <line x1="13" y1="16" x2="15" y2="16"/>
                            </svg>
                            Mes questionnaires
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_patient_profile') }}" class="nav-link active">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-user-edit me-2" width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <path d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0"/>
                                <path d="M6 21v-2a4 4 0 0 1 4 -4h3.5"/>
                                <path d="M18.42 15.61a2.1 2.1 0 0 1 2.97 2.97l-3.39 3.42h-3v-3l3.42 -3.39z"/>
                            </svg>
                            Mon profil
                        </a>
                    </li>
                </ul>
            </div>
        </div>

    </div>

    {# ── Formulaire ── #}
    <div class="col-md-9">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

        {# Section 1 : Informations personnelles #}
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-user me-2" width="20" height="20" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <circle cx="12" cy="7" r="4"/>
                        <path d="M6 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2"/>
                    </svg>
                    Informations personnelles
                </h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.firstName, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.firstName, {'attr': {'class': 'form-control' ~ (form.firstName.vars.errors|length ? ' is-invalid' : '')}}) }}
                        {{ form_errors(form.firstName) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.lastName, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.lastName, {'attr': {'class': 'form-control' ~ (form.lastName.vars.errors|length ? ' is-invalid' : '')}}) }}
                        {{ form_errors(form.lastName) }}
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.birthDate, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.birthDate, {'attr': {'class': 'form-control' ~ (form.birthDate.vars.errors|length ? ' is-invalid' : '')}}) }}
                        {{ form_errors(form.birthDate) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.gender, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.gender, {'attr': {'class': 'form-select'}}) }}
                        {{ form_errors(form.gender) }}
                    </div>
                </div>

                {# Email en lecture seule — non modifiable par le patient #}
                <div class="mb-3">
                    <label class="form-label text-muted">Adresse e-mail</label>
                    <input type="text" class="form-control" value="{{ user.email }}" disabled>
                    <div class="form-text text-muted">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-lock me-1" width="14" height="14" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                            <rect x="5" y="11" width="14" height="10" rx="2"/>
                            <circle cx="12" cy="16" r="1"/>
                            <path d="M8 11v-4a4 4 0 0 1 8 0v4"/>
                        </svg>
                        L'adresse e-mail est votre identifiant de connexion. Sa modification est gérée par votre neuropsychologue.
                    </div>
                </div>
            </div>
        </div>

        {# Section 2 : Sécurité #}
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-shield-lock me-2" width="20" height="20" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <path d="M12 3a12 12 0 0 0 8.5 3a12 12 0 0 1 -8.5 15a12 12 0 0 1 -8.5 -15a12 12 0 0 0 8.5 -3"/>
                        <circle cx="12" cy="11" r="1"/>
                        <line x1="12" y1="12" x2="12" y2="14.5"/>
                    </svg>
                    Sécurité
                </h3>
                <div class="card-subtitle text-muted">Laissez ces champs vides si vous ne souhaitez pas changer de mot de passe.</div>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    {{ form_label(form.currentPassword, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.currentPassword, {'attr': {'class': 'form-control' ~ (form.currentPassword.vars.errors|length ? ' is-invalid' : ''), 'placeholder': '••••••••'}}) }}
                    {% if form.currentPassword.vars.errors|length %}
                        <div class="invalid-feedback d-block">
                            {% for error in form.currentPassword.vars.errors %}
                                {{ error.message }}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
                <div class="mb-3">
                    {{ form_label(form.newPassword.first, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.newPassword.first, {'attr': {'class': 'form-control' ~ (form.newPassword.vars.errors|length ? ' is-invalid' : ''), 'placeholder': '••••••••'}}) }}
                </div>
                <div class="mb-3">
                    {{ form_label(form.newPassword.second, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.newPassword.second, {'attr': {'class': 'form-control' ~ (form.newPassword.vars.errors|length ? ' is-invalid' : ''), 'placeholder': '••••••••'}}) }}
                    {% if form.newPassword.vars.errors|length %}
                        <div class="invalid-feedback d-block">
                            {% for error in form.newPassword.vars.errors %}
                                {{ error.message }}
                            {% endfor %}
                        </div>
                    {% endif %}
                    <div class="form-text text-muted">Minimum 8 caractères, dont au moins un chiffre.</div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mb-5">
            <button type="submit" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-device-floppy me-1" width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M6 4h10l4 4v10a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2v-12a2 2 0 0 1 2 -2"/>
                    <circle cx="12" cy="14" r="2"/>
                    <polyline points="14 4 14 8 8 8 8 4"/>
                </svg>
                Enregistrer les modifications
            </button>
            <a href="{{ path('app_patient_dashboard') }}" class="btn btn-outline-secondary">Annuler</a>
        </div>

        {{ form_end(form) }}

        {# ── Zone de suppression définitive ── #}
        <hr class="my-5">
        <div class="card border-danger mb-5" style="border-width: 2px;">
            <div class="card-header bg-danger-lt">
                <h3 class="card-title text-danger">
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-alert-triangle me-2" width="20" height="20" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <path d="M12 9v4m0 4h.01"/>
                        <path d="M5.07 19h13.86a2 2 0 0 0 1.75 -2.97l-6.93 -12.02a2 2 0 0 0 -3.5 0l-6.93 12.02a2 2 0 0 0 1.75 2.97z"/>
                    </svg>
                    Zone de suppression définitive
                </h3>
            </div>
            <div class="card-body">
                <p class="text-muted mb-4">
                    Cette action est irréversible. Votre compte, votre anamnèse et tous vos questionnaires
                    seront définitivement effacés de la base de données.
                </p>
                <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteAccountModal">
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-trash me-1" width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <line x1="4" y1="7" x2="20" y2="7"/>
                        <line x1="10" y1="11" x2="10" y2="17"/>
                        <line x1="14" y1="11" x2="14" y2="17"/>
                        <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12"/>
                        <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3"/>
                    </svg>
                    Supprimer mon compte et mes données
                </button>
            </div>
        </div>

    </div>

</div>

{# ── Modale de confirmation ── #}
<div class="modal modal-blur fade" id="deleteAccountModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger">
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-alert-circle me-2" width="20" height="20" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <circle cx="12" cy="12" r="9"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    Confirmer la suppression
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body text-muted">
                Êtes-vous sûr ? Cette action est définitive et ne peut pas être annulée.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <form method="POST" action="{{ path('app_patient_delete_account') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}">
                    <button type="submit" class="btn btn-danger">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-trash me-1" width="16" height="16" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                            <line x1="4" y1="7" x2="20" y2="7"/>
                            <line x1="10" y1="11" x2="10" y2="17"/>
                            <line x1="14" y1="11" x2="14" y2="17"/>
                            <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12"/>
                            <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3"/>
                        </svg>
                        Oui, supprimer définitivement
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
